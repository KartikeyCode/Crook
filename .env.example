# CROO network endpoints
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://ws.croo.network

# SDK keys — one per agent, obtained from agent.croo.network dashboard
WHALE_TRACKER_SDK_KEY=your_whale_tracker_sdk_key_here
PROTOCOL_HEALTH_SDK_KEY=your_protocol_health_sdk_key_here
TOKEN_DD_SDK_KEY=your_token_dd_sdk_key_here
SENTIMENT_FUSION_SDK_KEY=your_sentiment_fusion_sdk_key_here
ALPHA_COMPOSER_SDK_KEY=your_alpha_composer_sdk_key_here

# Agent IDs — filled in after registering on agent.croo.network
WHALE_TRACKER_AGENT_ID=
PROTOCOL_HEALTH_AGENT_ID=
TOKEN_DD_AGENT_ID=
SENTIMENT_FUSION_AGENT_ID=

# Free API keys
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here
